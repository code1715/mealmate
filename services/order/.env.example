# Order Service environment variables

# Postgres connection
POSTGRES_URL=postgresql+asyncpg://mealmate:mealmate@postgres:5432/mealmate

# Redis connection
REDIS_URL=redis://redis:6379/1

# Kafka configuration
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC=order-status-changed

# Auth Service URL (for inter-service token validation)
AUTH_SERVICE_URL=http://auth:8000

# Routing Service URL (for courier matching on order confirmation)
ROUTING_SERVICE_URL=http://routing:8000
